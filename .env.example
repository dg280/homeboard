# Homeboard — variables d'environnement (à définir dans Vercel, jamais committées)

# --- Messages Telegram (existant) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Sync gratuite du board (Telegram) ---
# Le board (proches + infos, SANS photos) est stocké comme message épinglé d'un
# canal/groupe privé, lu/écrit par le bot via /api/board. Zéro base, zéro coût.
# Prérequis : le bot doit être ADMIN du canal (droit d'épingler les messages).
# IMPORTANT : utilise un canal DÉDIÉ (pas le chat famille), sinon le JSON du board
# polluerait le flux de messages. Si vide, la sync reste désactivée (off).
TELEGRAM_BOARD_CHAT_ID=

# --- Monétisation Premium (Gumroad) ---
# 1. Crée un produit Gumroad "Homeboard Premium" à 19€, coche "Generate license keys", publie-le.
# 2. GUMROAD_PRODUCT_ID = l'ID produit (Gumroad > produit > Settings/Advanced, ou via l'API).
#    Sert à la route serveur /api/license pour vérifier les clés. Privé.
GUMROAD_PRODUCT_ID=
# 3. NEXT_PUBLIC_GUMROAD_URL = l'URL publique d'achat du produit (ex: https://toncompte.gumroad.com/l/homeboard).
#    Bouton "Débloquer 19€". Public (préfixe NEXT_PUBLIC_).
NEXT_PUBLIC_GUMROAD_URL=
